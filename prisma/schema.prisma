generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum TreeType {
  HUMAN
  ANIMAL
}

enum TreeAccessRole {
  VIEWER
  EDITOR
  ADMIN
}

enum TreeEdgeType {
  PARENT
  CHILD
  SPOUSE
  COUPLE
}

enum TreeNodeGender {
  MALE
  FEMALE
  OTHER
  UNSPECIFIED
}

enum Language {
  CA
  ES
  EN
}

enum ActivityAction {
  NODE_CREATED
  NODE_UPDATED
  NODE_DELETED

  EDGE_CREATED
  EDGE_DELETED

  PICTURE_ADDED
  PICTURE_DELETED

  PICTURE_TAG_CREATED
  PICTURE_TAG_DELETED

  TREE_UPDATED

  SHARE_TOKEN_GENERATED
  MEMBER_JOINED_VIA_SHARE

  NOTE_UPDATED
}

model Tree {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  slug      String
  name      String
  type      TreeType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  newsletter Boolean @default(true)

  shareToken          String?
  shareTokenExpiresAt DateTime?

  nodes       TreeNode[]
  accesses    TreeAccess[]
  TreeEdge    TreeEdge[]
  Picture     Picture[]
  ActivityLog ActivityLog[]
  note        TreeNote?

  @@unique([slug])
  @@index([shareToken])
}

model TreeNode {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  tree   Tree   @relation(fields: [treeId], references: [id], onDelete: Cascade)
  treeId String @db.ObjectId

  fullName  String
  birthDate DateTime?
  deathDate DateTime?
  gender    TreeNodeGender @default(UNSPECIFIED)

  birthPlace String?
  deathPlace String?
  biography  String?
  alias      String?

  taggedIn  PictureTag[] @relation("taggedIn")
  edgesFrom TreeEdge[]   @relation("FromNode")
  edgesTo   TreeEdge[]   @relation("ToNode")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TreeEdge {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  tree   Tree   @relation(fields: [treeId], references: [id], onDelete: Cascade)
  treeId String @db.ObjectId

  fromNode   TreeNode @relation("FromNode", fields: [fromNodeId], references: [id], onDelete: Cascade)
  fromNodeId String   @db.ObjectId
  toNode     TreeNode @relation("ToNode", fields: [toNodeId], references: [id], onDelete: Cascade)
  toNodeId   String   @db.ObjectId

  type      TreeEdgeType
  createdAt DateTime     @default(now())

  @@index([fromNodeId])
  @@index([toNodeId])
}

model TreeAccess {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  tree   Tree   @relation(fields: [treeId], references: [id], onDelete: Cascade)
  treeId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @db.ObjectId

  role TreeAccessRole @default(VIEWER)

  createdAt DateTime @default(now())

  @@unique([treeId, userId])
  @@index([userId])
}

model Account {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId

  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @db.ObjectId

  sessionToken String   @unique
  expires      DateTime

  @@index([userId])
}

model User {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  image         String
  name          String
  email         String       @unique
  emailVerified DateTime?
  password      String?
  newsletter    Boolean      @default(true)
  language      Language @default(EN)

  accounts Account[]
  sessions Session[]

  TreeAccess  TreeAccess[]
  ActivityLog ActivityLog[]
  TreeNote    TreeNote[]
}

model Picture {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  tree   Tree   @relation(fields: [treeId], references: [id], onDelete: Cascade)
  treeId String @db.ObjectId

  fileKey    String
  uploadedBy String @db.ObjectId

  date     DateTime?
  metadata Json?

  tags PictureTag[] @relation("tags")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PictureTag {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  picture   Picture @relation("tags", fields: [pictureId], references: [id], onDelete: Cascade)
  pictureId String  @db.ObjectId

  node   TreeNode @relation("taggedIn", fields: [nodeId], references: [id], onDelete: Cascade)
  nodeId String   @db.ObjectId

  isProfile Boolean @default(false)

  @@unique([pictureId, nodeId])
}

model ActivityLog {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  tree   Tree   @relation(fields: [treeId], references: [id], onDelete: Cascade)
  treeId String @db.ObjectId

  action ActivityAction

  entityId String

  metadata Json?

  user      User?   @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  createdBy String? @db.ObjectId

  createdAt DateTime @default(now())
}

model TreeNote {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  tree   Tree   @relation(fields: [treeId], references: [id], onDelete: Cascade)
  treeId String @unique @db.ObjectId

  content String @default("")

  updatedBy   User?   @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  updatedById String? @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
