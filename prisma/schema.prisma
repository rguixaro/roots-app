generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum FamilyType {
  HUMAN
  ANIMAL
}

enum FamilyRole {
  VIEWER
  EDITOR
  ADMIN
}

enum TreeEdgeType {
  PARENT
  CHILD
  SPOUSE
  COUPLE
}

enum TreeNodeGender {
  MALE
  FEMALE
  OTHER
  UNSPECIFIED
}

model Family {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  slug        String
  name        String
  type        FamilyType
  nodeImage   Boolean    @default(false)
  nodeGallery Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  nodes    TreeNode[]
  accesses FamilyAccess[]
  TreeEdge TreeEdge[]

  @@unique([slug])
}

model TreeNode {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  familyId String @db.ObjectId

  fullName  String
  birthDate DateTime?
  deathDate DateTime?
  photoUrl  String?
  gender    TreeNodeGender @default(UNSPECIFIED)

  edgesFrom TreeEdge[] @relation("FromNode")
  edgesTo   TreeEdge[] @relation("ToNode")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TreeEdge {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  familyId String @db.ObjectId

  fromNode   TreeNode @relation("FromNode", fields: [fromNodeId], references: [id], onDelete: Cascade)
  fromNodeId String   @db.ObjectId
  toNode     TreeNode @relation("ToNode", fields: [toNodeId], references: [id], onDelete: Cascade)
  toNodeId   String   @db.ObjectId

  type      TreeEdgeType
  createdAt DateTime     @default(now())

  @@index([fromNodeId])
  @@index([toNodeId])
}

model FamilyAccess {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  familyId String @db.ObjectId
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String @db.ObjectId

  role FamilyRole @default(VIEWER)

  createdAt DateTime @default(now())

  @@unique([familyId, userId])
  @@index([userId])
}

model Account {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId

  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @db.ObjectId

  sessionToken String   @unique
  expires      DateTime

  @@index([userId])
}

model User {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  image         String
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String?
  isPrivate     Boolean   @default(true)

  accounts Account[]
  sessions Session[]

  FamilyAccess FamilyAccess[]
}
