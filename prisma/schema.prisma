generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum FamilyType {
  HUMAN
  ANIMAL
}

enum FamilyRole {
  VIEWER
  EDITOR
  ADMIN
}

model Family {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  slug        String
  name        String
  type        FamilyType
  nodeImage   Boolean    @default(false)
  nodeGallery Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  accesses FamilyAccess[]

  @@unique([slug])
}

model FamilyAccess {
  id       String     @id @default(auto()) @map("_id") @db.ObjectId
  family   Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)
  familyId String     @db.ObjectId
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String     @db.ObjectId
  role     FamilyRole @default(VIEWER)

  createdAt DateTime @default(now())

  @@unique([familyId, userId])
  @@index([userId])
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String   @db.ObjectId

  @@index([userId])
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  image         String
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String?
  isPrivate     Boolean   @default(true)
  accounts      Account[]
  sessions      Session[]

  FamilyAccess FamilyAccess[]
}
