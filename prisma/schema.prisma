generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum TreeType {
  HUMAN
  ANIMAL
}

enum TreeAccessRole {
  VIEWER
  EDITOR
  ADMIN
}

enum TreeEdgeType {
  PARENT
  CHILD
  SPOUSE
  COUPLE
}

enum TreeNodeGender {
  MALE
  FEMALE
  OTHER
  UNSPECIFIED
}

model Tree {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  slug        String
  name        String
  type        TreeType
  nodeImage   Boolean  @default(false)
  nodeGallery Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  nodes    TreeNode[]
  accesses TreeAccess[]
  TreeEdge TreeEdge[]
  Picture  Picture[]

  @@unique([slug])
}

model TreeNode {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  tree   Tree   @relation(fields: [treeId], references: [id], onDelete: Cascade)
  treeId String @db.ObjectId

  fullName  String
  birthDate DateTime?
  deathDate DateTime?
  gender    TreeNodeGender @default(UNSPECIFIED)

  taggedIn PictureTag[] @relation("taggedIn")

  edgesFrom TreeEdge[] @relation("FromNode")
  edgesTo   TreeEdge[] @relation("ToNode")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TreeEdge {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  tree   Tree   @relation(fields: [treeId], references: [id], onDelete: Cascade)
  treeId String @db.ObjectId

  fromNode   TreeNode @relation("FromNode", fields: [fromNodeId], references: [id], onDelete: Cascade)
  fromNodeId String   @db.ObjectId
  toNode     TreeNode @relation("ToNode", fields: [toNodeId], references: [id], onDelete: Cascade)
  toNodeId   String   @db.ObjectId

  type      TreeEdgeType
  createdAt DateTime     @default(now())

  @@index([fromNodeId])
  @@index([toNodeId])
}

model TreeAccess {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  tree   Tree   @relation(fields: [treeId], references: [id], onDelete: Cascade)
  treeId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @db.ObjectId

  role TreeAccessRole @default(VIEWER)

  createdAt DateTime @default(now())

  @@unique([treeId, userId])
  @@index([userId])
}

model Account {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId

  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @db.ObjectId

  sessionToken String   @unique
  expires      DateTime

  @@index([userId])
}

model User {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  image         String
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String?
  isPrivate     Boolean   @default(true)

  accounts Account[]
  sessions Session[]

  TreeAccess TreeAccess[]
}

model Picture {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  tree   Tree   @relation(fields: [treeId], references: [id], onDelete: Cascade)
  treeId String @db.ObjectId

  fileKey    String
  uploadedBy String @db.ObjectId

  tags PictureTag[] @relation("tags")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PictureTag {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  picture   Picture @relation("tags", fields: [pictureId], references: [id], onDelete: Cascade)
  pictureId String  @db.ObjectId

  node   TreeNode @relation("taggedIn", fields: [nodeId], references: [id], onDelete: Cascade)
  nodeId String   @db.ObjectId

  isProfile Boolean @default(false)

  @@unique([pictureId, nodeId])
}
